{
	"compilerOptions": {
		"strict": true,
		"checkJs": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"lib": [
			"es2022"
		],
		"module": "node16",
		"target": "es2022"
	},
  "exclude": [
    "coverage/",
    "node_modules/"
  ],
  "include": [
    "*.js",
    "index.d.ts"
  ]
}
